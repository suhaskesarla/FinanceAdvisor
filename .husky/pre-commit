#!/bin/sh

echo "Running pre-commit checks..."

# 1. Format check
dotnet format --verify-no-changes --severity error
if [ $? -ne 0 ]; then
  echo ""
  echo "FORMAT FAILED: Run 'dotnet format' to fix formatting before committing."
  exit 1
fi

# 2. Clean then build — clean prevents MSBuild file deletion warnings
dotnet clean -q
dotnet build --configuration Release -q
if [ $? -ne 0 ]; then
  echo ""
  echo "BUILD FAILED: Fix all build errors before committing."
  exit 1
fi

echo "Pre-commit checks passed."